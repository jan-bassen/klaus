{
  "name": "klaus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/__tests__/context src/__tests__/core src/__tests__/whatsapp src/__tests__/tools src/__tests__/commands src/__tests__/logger.test.ts",
    "test:pipeline": "bun test src/__tests__/pipeline.test.ts",
    "test:db": "RUN_DB_TESTS=1 bun test --serial src/__tests__/db",
    "test:watch": "bun test --watch",
    "docker:up": "docker compose up -d postgres",
    "docker:build": "docker compose build app",
    "docker:start": "docker compose up -d",
    "docker:logs": "docker compose logs -f app",
    "docker:pair": "docker compose logs -f app",
    "docker:stop": "docker compose down",
    "docker:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.48",
    "@whiskeysockets/baileys": "^6.7.0",
    "ai": "^6.0.103",
    "drizzle-orm": "^0.38.0",
    "handlebars": "^4.7.8",
    "pg-boss": "^10.0.0",
    "postgres": "^3.4.0",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.5",
    "voyage-ai-provider": "^3.0.0",
    "yaml": "^2.8.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/handlebars": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "bun-types": "^1.3.10",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
