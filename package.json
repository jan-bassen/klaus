{
  "name": "klaus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:db": "DATABASE_URL=postgres://postgres:postgres@localhost:5432/klaus_test bun test src/__tests__/db",
    "test:watch": "bun test --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate-test": "DATABASE_URL=postgres://postgres:postgres@localhost:5432/klaus_test drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.48",
    "@ai-sdk/openai": "^3.0.36",
    "@whiskeysockets/baileys": "^6.7.0",
    "ai": "^6.0.103",
    "drizzle-orm": "^0.38.0",
    "pg-boss": "^10.0.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.10",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
