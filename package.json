{
	"name": "klaus",
	"version": "0.2.0",
	"private": true,
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"build": "docker build -t klaus .",
		"publish": "docker buildx build --platform linux/amd64 --build-arg VERSION=$(jq -r .version package.json) -t janbassen1/klaus:$(jq -r .version package.json) -t janbassen1/klaus:latest --push ."
	},
	"dependencies": {
		"@llamaindex/liteparse": "^1.5.0",
		"@openrouter/sdk": "^0.12.21",
		"@whiskeysockets/baileys": "^6.7.0",
		"croner": "^10.0.1",
		"handlebars": "^4.7.8",
		"qrcode": "^1.5.4",
		"sharp": "^0.34.5",
		"yaml": "^2.8.2",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@types/bun": "^1.3.9",
		"@types/handlebars": "^4.1.0",
		"@types/node": "^22.0.0",
		"@types/qrcode": "^1.5.6",
		"bun-types": "^1.3.10",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0"
	}
}
