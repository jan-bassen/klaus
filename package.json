{
	"name": "klaus",
	"version": "0.2.5",
	"private": true,
	"type": "module",
	"packageManager": "npm@11.12.1",
	"engines": {
		"node": ">=25"
	},
	"scripts": {
		"dev": "docker run --rm -it --env-file .env -v klaus-vault:/vault -v klaus-data:/data klaus",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"build": "docker build -t klaus ."
	},
	"dependencies": {
		"@llamaindex/liteparse": "^1.5.3",
		"@openrouter/sdk": "^0.12.35",
		"baileys": "^7.0.0-rc11",
		"croner": "^10.0.1",
		"handlebars": "^4.7.9",
		"mathjs": "^15.2.0",
		"qrcode": "^1.5.4",
		"sharp": "^0.34.5",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/node": "^25.9.0",
		"@types/qrcode": "^1.5.6",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	}
}
