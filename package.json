{
	"name": "klaus",
	"version": "0.2.0",
	"private": true,
	"type": "module",
	"packageManager": "npm@11.12.1",
	"engines": {
		"node": ">=25"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"build": "docker build -t klaus .",
		"publish": "docker buildx build --platform linux/amd64 --build-arg VERSION=$(jq -r .version package.json) -t janbassen1/klaus:$(jq -r .version package.json) -t janbassen1/klaus:latest --push ."
	},
	"dependencies": {
		"@llamaindex/liteparse": "^1.5.2",
		"@openrouter/sdk": "^0.12.22",
		"baileys": "^7.0.0-rc.9",
		"croner": "^10.0.1",
		"handlebars": "^4.7.9",
		"mathjs": "^15.2.0",
		"qrcode": "^1.5.4",
		"sharp": "^0.34.5",
		"yaml": "^2.8.3",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@types/node": "^25.6.0",
		"@types/qrcode": "^1.5.6",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"overrides": {
		"protobufjs": "^7.5.5"
	}
}
