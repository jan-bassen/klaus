{
	"name": "klaus",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "for f in $(find src/__tests__ -name '*.test.ts' | sort); do bun test \"$f\" || exit 1; done",
		"test:watch": "bun test --watch",
		"build": "docker compose build app",
		"up": "docker compose up -d",
		"logs": "docker compose logs -f app",
		"init": "docker compose up -d && docker compose logs -f app",
		"down": "docker compose down"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.48",
		"@whiskeysockets/baileys": "^6.7.0",
		"ai": "^6.0.103",
		"handlebars": "^4.7.8",
		"qrcode-terminal": "^0.12.0",
		"sharp": "^0.34.5",
		"yaml": "^2.8.2",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@types/bun": "^1.3.9",
		"@types/handlebars": "^4.1.0",
		"@types/node": "^22.0.0",
		"@types/qrcode-terminal": "^0.12.2",
		"bun-types": "^1.3.10",
		"typescript": "^5.7.0"
	}
}
