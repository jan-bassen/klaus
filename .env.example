# All secrets are stored in 1Password and resolved at runtime via `op run`.
# Replace op:// URIs with your actual vault/item paths.
# Non-secrets are plain values and safe to keep as-is.

# Database (non-secret — Postgres runs locally/in Docker with default creds)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/klaus

# LLM
ANTHROPIC_API_KEY=op://Personal/Klaus/ANTHROPIC_API_KEY

# Embeddings (Voyage AI — https://docs.voyageai.com)
VOYAGE_API_KEY=op://Personal/Klaus/VOYAGE_API_KEY

# Speech (ElevenLabs — https://elevenlabs.io)
ELEVENLABS_API_KEY=op://Personal/Klaus/ELEVENLABS_API_KEY

# Allowed WhatsApp chat ID (e.g. 4917612345678@s.whatsapp.net)
ALLOWED_CHAT_ID=op://Personal/Klaus/ALLOWED_CHAT_ID

# Baileys auth state directory — must match .gitignore entry (.auth/)
BAILEYS_AUTH_FOLDER=./.auth

# Internal app port — only Caddy talks to this directly
PORT=3000

# ── NAS / production only ─────────────────────────────────────────────────────

# Public domain for Caddy (auto-manages TLS via Let's Encrypt)
# DOMAIN=your.domain.com

# 1Password service account token for headless secret resolution on the NAS.
# Set this as a GitHub Actions secret (OP_SERVICE_ACCOUNT_TOKEN) — the runner
# and deploy workflow will pick it up automatically.
# OP_SERVICE_ACCOUNT_TOKEN=ops_...
