# ── LLM ────────────────────────────────────────────────────────────────────
# Default endpoint. Required unless you add direct provider endpoints in
# vault/Klaus/settings.yml and route every provider away from openrouter.
OPENROUTER_API_KEY=

# ── Voice (optional) ───────────────────────────────────────────────────────
# Required if any agent uses TTS/STT (voice: on|auto). Omit for text-only.
ELEVENLABS_API_KEY=

# ── Obsidian Sync ──────────────────────────────────────────────────────────
# Required. Klaus supervises `obsidian-headless` in-container; these creds
# log it in and link it to your remote vault on first boot. Login state is
# cached under {DATA_DIR}/obsidian-headless so subsequent boots skip setup.
OBSIDIAN_EMAIL=
OBSIDIAN_PASSWORD=
OBSIDIAN_VAULT_NAME=

# Optional — only needed if your vault is end-to-end encrypted.
# OBSIDIAN_E2EE_PASSWORD=

# ── Paths (optional) ───────────────────────────────────────────────────────
# Vault root. Default: ./vault. In Docker, mount your vault here.
# VAULT_DIR=/app/vault
# Operational state (history, files, schedules, sync config, baileys auth).
# Default: ~/.klaus/data. In Docker, mount a volume here.
# DATA_DIR=/app/data

# ── Misc (optional) ────────────────────────────────────────────────────────
# PORT=3000
# LOG_FORMAT=text          # text | json
# STARTUP_CONNECTION_WARN_AFTER_MS=60000
# BAILEYS_AUTH_FOLDER=.baileys-auth

# ── Allowlist override (optional) ──────────────────────────────────────────
# Normally written automatically during setup (solo-mode checkbox or 6-digit
# code) into vault/Klaus/settings.yml. Set here only to pin the chat
# manually, e.g. for headless tests.
# ALLOWED_CHAT_ID=
