# Non-secret configuration. Copy to .env — safe to keep as-is for most setups.
# API keys and secrets go in .env.secrets (gitignored, never committed).

# Database (Postgres runs in Docker with these defaults — change if needed)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/klaus

# Baileys auth state directory — must match .gitignore entry (.auth/)
BAILEYS_AUTH_FOLDER=./.auth

# Internal app port — only Caddy talks to this directly
PORT=3000

# ── NAS / production only ─────────────────────────────────────────────────────
# These are filled in automatically by scripts/setup-nas.sh — don't edit manually.

# Public domain for Caddy (auto-manages TLS via Let's Encrypt)
# DOMAIN=your.domain.com

# GitHub Actions self-hosted runner — auto-populated by setup-nas.sh
# GITHUB_REPO_URL=https://github.com/your/repo
# GITHUB_RUNNER_TOKEN=your-runner-token
