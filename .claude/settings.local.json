{
  "permissions": {
    "allow": [
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:github.com)",
      "Bash(bun install)",
      "Bash(bun run typecheck)",
      "Bash(bun add -d bun-types)",
      "Bash(docker info --format '{{.ServerVersion}}')",
      "Bash(bun run test:db)",
      "Bash(bun test src/__tests__/context src/__tests__/core/agent.test.ts)",
      "Bash(bun run tsc --noEmit)",
      "Bash(bun test --testPathPattern=\"src/__tests__/\\(context|core/agent\\)\")",
      "Bash(bun test --testPathPattern=\"src/__tests__/db\")",
      "Bash(bun test)",
      "Bash(bun test src/__tests__/db/write.test.ts)",
      "Bash(bun test src/__tests__/context/graph.test.ts)",
      "Bash(bun test --verbose)",
      "Bash(bun test src/__tests__/db/)",
      "Bash(bun tsc --noEmit)",
      "Bash(bun run db:generate)"
    ]
  }
}
