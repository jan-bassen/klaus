# Non-secret configuration. Copy to .env — safe to keep as-is for most setups.
# API keys and secrets go in .env.secrets (gitignored, never committed).

# ── Postgres ─────────────────────────────────────────────────────────────────
# Credentials used to initialise the container AND to build DATABASE_URL.
# If you change these, update DATABASE_URL below to match.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=klaus
# Host-side port exposed by docker-compose. Change if 5433 conflicts locally.
POSTGRES_HOST_PORT=5433

# Database connection URL — used by the app in native/local dev.
# docker-compose overrides this internally (uses service name 'postgres').
DATABASE_URL=postgres://postgres:postgres@localhost:5433/klaus

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
# Log output format: pretty (human-readable) or json (newline-delimited, for log aggregators).
LOG_FORMAT=pretty

# ── Drizzle Studio ────────────────────────────────────────────────────────────
STUDIO_PORT=4984

# ── Paths ─────────────────────────────────────────────────────────────────────
# Baileys auth state directory — must match .gitignore entry (.auth/)
BAILEYS_AUTH_FOLDER=./auth

# Where to store backups on the host (created by `./run.sh backup`)
# Default: ./backups (works on laptop); NAS: /volume1/backups/klaus
# BACKUP_DIR=./backups

# Obsidian vault directory — must match the Docker volume mount
# VAULT_DIR=/app/vault
