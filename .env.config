# Non-secret configuration. Copy to .env — safe to keep as-is for most setups.
# API keys and secrets go in .env.secrets (gitignored, never committed).

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
# Log output format: pretty (human-readable) or json (newline-delimited, for log aggregators).
LOG_FORMAT=pretty

# ── Paths ─────────────────────────────────────────────────────────────────────
# Baileys auth state directory — must match .gitignore entry (.auth/)
BAILEYS_AUTH_FOLDER=./auth

# Where to store backups on the host (created by `./run.sh backup`)
# Default: ./backups (works on laptop); NAS: /volume1/backups/klaus
# BACKUP_DIR=./backups

# Obsidian vault directory — must match the Docker volume mount
# VAULT_DIR=/Users/janbassen/path/to/your/obsidian/vault
